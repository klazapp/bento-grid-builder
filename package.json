{
  "name": "bento-grid-builder",
  "version": "0.2.1",
  "description": "A flexible, configurable bento grid layout system for React",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^18.2.0",
    "jsdom": "^28.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "bento",
    "grid",
    "layout",
    "react",
    "dashboard",
    "cards",
    "bento-grid",
    "css-grid"
  ],
  "license": "MIT",
  "author": "klazapp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klazapp/bento-grid-builder.git"
  },
  "homepage": "https://github.com/klazapp/bento-grid-builder#readme",
  "bugs": {
    "url": "https://github.com/klazapp/bento-grid-builder/issues"
  }
}
